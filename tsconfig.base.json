{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@evidoc/core": ["packages/core/src/index.ts"],
      "@evidoc/cli": ["packages/cli/src/index.ts"],
      "@evidoc/dashboard": ["packages/dashboard/src/index.ts"],
      "@evidoc/evidoc": ["packages/evidoc/src/index.ts"],
      "@evidoc/frontmatter": ["packages/frontmatter/src/index.ts"],
      "@evidoc/github-action": ["packages/github-action/src/index.ts"],
      "@evidoc/graph": ["packages/graph/src/index.ts"],
      "@evidoc/local-app": ["packages/local-app/src/index.ts"],
      "@evidoc/mcp-server": ["packages/mcp-server/src/index.ts"],
      "@evidoc/patcher": ["packages/patcher/src/index.ts"],
      "@evidoc/reports": ["packages/reports/src/index.ts"],
      "@evidoc/review-log": ["packages/review-log/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
